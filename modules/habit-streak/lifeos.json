{
  "name": "habit-streak",
  "version": "0.1.0",
  "author": "lifeos-community",
  "description": "Track daily habits, preserve streaks, and surface milestone celebrations with local-first graph storage.",
  "permissions": {
    "graph": ["read", "append"],
    "network": [],
    "voice": ["speak"],
    "events": [
      "subscribe:lifeos.tick.overdue",
      "subscribe:lifeos.voice.intent.habit.create",
      "subscribe:lifeos.voice.intent.habit.checkin",
      "subscribe:lifeos.voice.intent.habit.status",
      "publish:lifeos.habit.checkin.recorded",
      "publish:lifeos.habit.streak.milestone",
      "publish:lifeos.orchestrator.suggestion"
    ]
  },
  "resources": {
    "cpu": "low",
    "memory": "low"
  },
  "requires": [
    "@lifeos/cli@>=0.1.0 <0.2.0",
    "@lifeos/module-sdk@>=0.1.0 <0.2.0"
  ],
  "category": "productivity",
  "tags": ["habit", "streak", "tracking", "daily"]
}
