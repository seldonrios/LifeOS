{
  "name": "calendar",
  "version": "0.1.0",
  "author": "lifeos-core",
  "description": "Calendar planning and event coordination module",
  "permissions": {
    "graph": ["read", "append"],
    "network": [],
    "voice": [],
    "events": [
      "subscribe:lifeos.voice.intent.calendar.add",
      "subscribe:lifeos.tick.overdue",
      "publish:lifeos.calendar.event.added"
    ]
  },
  "resources": {
    "cpu": "low",
    "memory": "low"
  },
  "requires": ["@lifeos/life-graph@>=0.3.0 <0.4.0", "@lifeos/event-bus@>=0.3.0 <0.4.0"],
  "category": "productivity",
  "tags": ["calendar", "planning"]
}
