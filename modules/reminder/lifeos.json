{
  "name": "reminder",
  "version": "0.1.0",
  "author": "lifeos-core",
  "description": "Reminder reactions for overdue and task events",
  "permissions": {
    "graph": ["read", "append"],
    "network": [],
    "voice": ["speak"],
    "events": [
      "subscribe:lifeos.tick.overdue",
      "subscribe:lifeos.task.completed",
      "subscribe:task.scheduled",
      "publish:lifeos.reminder.followup.created"
    ]
  },
  "resources": {
    "cpu": "low",
    "memory": "low"
  },
  "requires": ["@lifeos/event-bus@>=0.3.0 <0.4.0"],
  "category": "productivity",
  "tags": ["reminder", "tasks"]
}
