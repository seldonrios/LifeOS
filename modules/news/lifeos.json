{
  "name": "news",
  "version": "0.1.0",
  "author": "lifeos-core",
  "description": "News digest generation with local caching",
  "permissions": {
    "graph": ["read", "append"],
    "network": ["news", "rss"],
    "voice": ["speak"],
    "events": ["subscribe:lifeos.voice.intent.news", "publish:lifeos.news.digest.created"]
  },
  "resources": {
    "cpu": "medium",
    "memory": "low"
  },
  "requires": ["@lifeos/life-graph@>=0.3.0 <0.4.0", "@lifeos/event-bus@>=0.3.0 <0.4.0"],
  "category": "information",
  "tags": ["news", "digest"]
}
