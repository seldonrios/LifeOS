{
  "name": "home-state",
  "version": "0.1.0",
  "author": "lifeos-community",
  "description": "Home Assistant bridge utilities for household state changes and HA voice capture forwarding.",
  "permissions": {
    "graph": ["read"],
    "network": [],
    "voice": [],
    "events": [
      "subscribe:lifeos.household.homestate.changed",
      "subscribe:lifeos.household.voice.capture.created",
      "publish:lifeos.household.homestate.changed",
      "publish:lifeos.household.voice.capture.created"
    ]
  },
  "resources": {
    "cpu": "low",
    "memory": "low"
  },
  "requires": ["@lifeos/cli@>=0.1.0 <0.2.0", "@lifeos/module-sdk@>=0.1.0 <0.2.0"],
  "category": "household",
  "tags": ["home-assistant", "presence", "household", "privacy"]
}
