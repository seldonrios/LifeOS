{
  "name": "scheduler",
  "version": "0.1.0",
  "author": "lifeos-core",
  "description": "Task scheduling and overdue handling module",
  "permissions": {
    "graph": ["read", "append", "write"],
    "network": [],
    "voice": [],
    "events": [
      "subscribe:lifeos.voice.intent.task.add",
      "subscribe:lifeos.tick.overdue",
      "publish:lifeos.task.reschedule.suggested"
    ]
  },
  "resources": {
    "cpu": "low",
    "memory": "low"
  },
  "requires": ["@lifeos/life-graph@>=0.3.0 <0.4.0", "@lifeos/event-bus@>=0.3.0 <0.4.0"],
  "category": "productivity",
  "tags": ["tasks", "scheduler"]
}
