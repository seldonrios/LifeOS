{
  "name": "notes",
  "version": "0.1.0",
  "author": "lifeos-core",
  "description": "Voice-first notes capture and retrieval module",
  "permissions": {
    "graph": ["read", "append"],
    "network": [],
    "voice": [],
    "events": [
      "subscribe:lifeos.voice.intent.note.add",
      "subscribe:lifeos.voice.intent.note.search",
      "subscribe:agent.work.requested",
      "publish:lifeos.note.added",
      "publish:lifeos.note.search.completed"
    ]
  },
  "resources": {
    "cpu": "low",
    "memory": "low"
  },
  "requires": ["@lifeos/life-graph@>=0.3.0 <0.4.0", "@lifeos/event-bus@>=0.3.0 <0.4.0"],
  "category": "knowledge",
  "tags": ["notes", "memory"]
}
