{
  "name": "voice",
  "version": "0.1.0",
  "author": "lifeos-core",
  "description": "Voice interaction and wake-word orchestration module",
  "permissions": {
    "graph": ["read"],
    "network": [],
    "voice": ["speak", "listen"],
    "events": ["subscribe:lifeos.voice.command.received", "publish:lifeos.voice.command.processed"]
  },
  "resources": {
    "cpu": "medium",
    "memory": "medium"
  },
  "requires": ["@lifeos/voice-core@>=0.3.0 <0.4.0", "@lifeos/event-bus@>=0.3.0 <0.4.0"],
  "category": "assistant",
  "tags": ["voice", "assistant"]
}
