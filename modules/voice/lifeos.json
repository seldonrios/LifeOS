{
  "name": "voice",
  "version": "0.1.0",
  "author": "lifeos-core",
  "description": "Voice interaction and wake-word orchestration module",
  "permissions": {
    "graph": ["read"],
    "network": [],
    "voice": ["speak", "listen"],
    "events": [
      "subscribe:lifeos.homenode.voice.session.started",
      "subscribe:lifeos.homenode.voice.session.completed",
      "subscribe:lifeos.homenode.voice.session.failed",
      "subscribe:lifeos.household.voice.capture.created",
      "publish:lifeos.homenode.voice.session.started",
      "publish:lifeos.homenode.voice.session.completed",
      "publish:lifeos.homenode.voice.session.failed"
    ]
  },
  "resources": {
    "cpu": "medium",
    "memory": "medium"
  },
  "requires": ["@lifeos/module-sdk@>=0.1.0 <0.2.0", "@lifeos/event-bus@>=0.3.0 <0.4.0"],
  "category": "assistant",
  "tags": ["voice", "assistant"]
}
