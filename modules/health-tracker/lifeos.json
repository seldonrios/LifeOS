{
  "name": "health-tracker",
  "version": "0.1.0",
  "author": "lifeos-community",
  "description": "Log health metrics locally - steps, sleep, weight, heart rate, and custom metrics.",
  "permissions": {
    "graph": ["read", "append"],
    "network": [],
    "voice": ["speak"],
    "events": [
      "subscribe:lifeos.tick.overdue",
      "subscribe:lifeos.voice.intent.health.log",
      "subscribe:lifeos.voice.intent.health.query",
      "publish:lifeos.health.metric.logged",
      "publish:lifeos.health.streak.updated",
      "publish:lifeos.orchestrator.suggestion"
    ]
  },
  "resources": {
    "cpu": "low",
    "memory": "low"
  },
  "requires": [
    "@lifeos/life-graph@>=0.3.0 <0.4.0",
    "@lifeos/event-bus@>=0.3.0 <0.4.0",
    "@lifeos/voice-core@>=0.3.0 <0.4.0"
  ],
  "category": "health",
  "tags": ["health", "metrics", "tracking", "habit"]
}
