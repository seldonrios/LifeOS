{
  "name": "research",
  "version": "0.1.0",
  "author": "lifeos-core",
  "description": "Local research assistant with summarized memory output",
  "permissions": {
    "graph": ["read", "append"],
    "network": [],
    "voice": ["speak"],
    "events": ["subscribe:lifeos.voice.intent.research", "publish:lifeos.research.completed"]
