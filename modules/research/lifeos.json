  "resources": {
    "cpu": "high",
    "memory": "medium"
  },
  "requires": ["@lifeos/life-graph@>=0.3.0 <0.4.0", "@lifeos/event-bus@>=0.3.0 <0.4.0"],
  "category": "knowledge",
  "tags": ["research", "assistant"]
}
