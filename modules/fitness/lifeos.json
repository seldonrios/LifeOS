{
  "name": "fitness",
  "version": "0.1.0",
  "author": "lifeos-core",
  "description": "Fitness and habit tracking module",
  "permissions": {
    "graph": ["read", "append"],
    "network": [],
    "voice": ["speak"],
    "events": ["subscribe:lifeos.tick", "publish:lifeos.fitness.update"]
  },
  "resources": {
    "cpu": "low",
    "memory": "low"
  },
  "requires": [
    "@lifeos/life-graph@>=0.3.0 <0.4.0",
    "@lifeos/event-bus@>=0.3.0 <0.4.0",
    "@lifeos/voice-core@>=0.3.0 <0.4.0"
  ],
  "category": "health",
  "tags": ["fitness", "habit"]
}
