{
  "name": "@lifeos/desktop",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:msvc": "cmd /c scripts\\dev-msvc.cmd",
    "dev:msvc:tauri-only": "set LIFEOS_SKIP_WEB=1&& cmd /c scripts\\dev-msvc.cmd",
    "dev:before-tauri": "pnpm run sidecar:build && pnpm run dev:web",
    "dev:web": "vite",
    "build": "tauri build",
    "build:before-tauri": "pnpm run sidecar:build && pnpm run sidecar:package && pnpm run build:web",
    "build:web": "vite build",
    "sidecar:build": "pnpm --dir sidecar build",
    "sidecar:package": "pnpm --dir sidecar build:release",
    "sidecar:package:msvc": "node ./scripts/package-msvc-sidecar.mjs",
    "sidecar:package:linux": "node ./scripts/package-linux-sidecar.mjs",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run test:web && pnpm run test:sidecar && pnpm run test:rust",
    "test:web": "vitest run",
    "test:sidecar": "pnpm --dir sidecar test",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@lifeos/cli": "workspace:*",
    "@lifeos/contracts": "workspace:*",
    "@tanstack/react-query": "^5.99.0",
    "@tauri-apps/api": "^2.10.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-force-graph-2d": "^1.29.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
