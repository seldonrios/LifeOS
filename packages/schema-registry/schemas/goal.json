{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lifeos.dev/schemas/goal.json",
  "title": "Goal Domain Event",
  "description": "Schema stub for goal.* events such as goal.proposed and goal.completed.",
  "type": "object",
  "required": ["id", "type", "source", "timestamp", "version", "data"],
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string", "pattern": "^goal\\..+" },
    "source": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "version": { "type": "string" },
    "data": {
      "type": "object",
      "properties": {
        "goalId": { "type": "string" },
        "status": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
