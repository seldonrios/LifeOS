{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lifeos.dev/schemas/production.json",
  "title": "Production Domain Event",
  "description": "Schema stub for production.* and homestead.* events.",
  "type": "object",
  "required": ["id", "type", "source", "timestamp", "version", "data"],
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string", "pattern": "^(production|homestead)\\..+" },
    "source": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "version": { "type": "string" },
    "data": {
      "type": "object",
      "properties": {
        "entityId": { "type": "string" },
        "changeType": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
