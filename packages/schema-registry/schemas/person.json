{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lifeos.dev/schemas/person.json",
  "title": "Person Domain Event",
  "description": "Schema stub for person.* events such as person.health.updated.",
  "type": "object",
  "required": ["id", "type", "source", "timestamp", "version", "data"],
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string", "pattern": "^person\\..+" },
    "source": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "version": { "type": "string" },
    "data": {
      "type": "object",
      "properties": {
        "personId": { "type": "string" },
        "profileVersion": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
