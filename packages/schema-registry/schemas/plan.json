{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lifeos.dev/schemas/plan.json",
  "title": "Plan Domain Event",
  "description": "Schema stub for plan.* and replan.* events.",
  "type": "object",
  "required": ["id", "type", "source", "timestamp", "version", "data"],
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string", "pattern": "^(plan|replan)\\..+" },
    "source": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "version": { "type": "string" },
    "data": {
      "type": "object",
      "properties": {
        "planId": { "type": "string" },
        "goalId": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
