{
  "name": "@lifeos/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "lifeos": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./errors": {
      "types": "./src/errors.ts",
      "default": "./src/errors.ts"
    }
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -b",
    "test": "tsx --test src/index.test.ts src/goal-interpreter.test.ts src/errors.test.ts src/hero-loop.integration.test.ts src/commands/init.test.ts src/commands/marketplace.test.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@lifeos/contracts": "workspace:*",
    "@lifeos/calendar-module": "workspace:*",
    "@lifeos/core": "workspace:*",
    "@lifeos/email-summarizer-module": "workspace:*",
    "@lifeos/event-bus": "workspace:*",
    "@lifeos/goal-engine": "workspace:*",
    "@lifeos/google-bridge": "workspace:*",
    "@lifeos/habit-streak-module": "workspace:*",
    "@lifeos/household-capture-router-module": "workspace:*",
    "@lifeos/household-chores-module": "workspace:*",
    "@lifeos/household-shopping-module": "workspace:*",
    "@lifeos/life-graph": "workspace:*",
    "@lifeos/mesh": "workspace:*",
    "@lifeos/module-loader": "workspace:*",
    "@lifeos/news-module": "workspace:*",
    "@lifeos/notes-module": "workspace:*",
    "@lifeos/orchestrator": "workspace:*",
    "@lifeos/reminder-module": "workspace:*",
    "@lifeos/research-module": "workspace:*",
    "@lifeos/scheduler-module": "workspace:*",
    "@lifeos/sync-core": "workspace:*",
    "@lifeos/voice-core": "workspace:*",
    "@lifeos/weather-module": "workspace:*",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "inquirer": "^13.3.2",
    "ora": "^9.3.0"
  }
}
