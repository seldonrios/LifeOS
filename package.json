{
  "name": "lifeos-monorepo",
  "private": true,
  "version": "0.3.0",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "husky install .husky",
    "lifeos": "pnpm --filter @lifeos/cli exec tsx src/index.ts",
    "build:modules": "tsx scripts/build-modules.ts",
    "validate": "pnpm run build:modules && pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test",
    "test": "tsx scripts/test-runner.ts",
    "test:graph": "vitest run packages/life-graph --coverage",
    "test:loader": "vitest run packages/module-loader --coverage",
    "lint": "eslint \"packages/**/*.{ts,tsx}\" \"modules/**/*.{ts,tsx}\" && tsx scripts/ruff-task.ts check",
    "format": "prettier --write . && tsx scripts/ruff-task.ts format",
    "format:check": "prettier --check . && tsx scripts/ruff-task.ts format-check",
    "typecheck": "tsc --build tsconfig.packages.json",
    "scaffold": "tsx scripts/scaffold.ts",
    "changeset": "changeset",
    "release:status": "changeset status --verbose",
    "release:version": "changeset version"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "modules/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "packages/**/*.py": [
      "ruff format",
      "ruff check --fix"
    ],
    "**/*.{json,yaml,yml,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@types/node": "^22",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
